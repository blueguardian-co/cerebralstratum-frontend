# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
.idea
# dependencies
/node_modules
webApp/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
webApp/dist/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# runtime env config populated with real local-dev values (ADR-0006);
# only the ${VAR} template belongs in git
webApp/public/env.js

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Kotlin Multiplatform specific
.gradle/
.kotlin/
**/build/
local.properties

# Native (iOS & Android)
*.iml
.idea/workspace.xml
.idea/tasks.xml
.idea/gradle.xml
.idea/assetWizardSettings.xml
.idea/dictionaries
.idea/libraries/
.idea/caches
.idea/modules.xml
.idea/navEditor.xml
.idea/shelf

# iOS specific
**/xcuserdata/
**/ios/Pods/
**/ios/Podfile.lock
**/iosApp/build/

# Android specific
**/captures/
.externalNativeBuild
.cxx/

# Shared KMP module
/shared/build/
